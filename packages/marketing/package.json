{
  "name": "@autostackup/marketing",
  "version": "0.1.5",
  "description": "Give Claude a marketing brain. Kotler 9-element marketing mix audit, full IMC campaign planning across Meta & Google, and audience segmentation — the frameworks Fortune 500 CMOs use, built as MCP tools.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "autostackup-marketing": "dist/server.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "mcp",
    "autostackup",
    "marketing",
    "kotler",
    "imc",
    "meta",
    "google-ads"
  ],
  "mcpName": "io.github.autostackup/marketing",
  "license": "MIT",
  "dependencies": {
    "@autostackup/core": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "rimraf": "^6.0.0"
  }
}
